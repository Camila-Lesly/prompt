@startuml controladores
title Diagrama de Controladores - myUniverse

skinparam linetype ortho
skinparam packageStyle rectangle
skinparam shadowing false
skinparam roundCorner 5
skinparam class {
    BackgroundColor white
    BorderColor #555555
    ArrowColor #333333
}

package "Controllers" as Controllers {

    control "EspacioController"       as EspacioController
    control "IniciarSesionController" as IniciarSesionController
    control "RecorridoController"     as RecorridoController
    control "VisitaController"        as VisitaController
}

@enduml

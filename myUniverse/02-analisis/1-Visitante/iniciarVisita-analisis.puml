@startuml iniciarVisita-analisis
skinparam linetype polyline

actor Visitante
package iniciarVisita as "iniciarVisita()" {
    rectangle #629EF9 WelcomeView
    rectangle #b5bd68 VisitaController
    rectangle #F2AC4E Visita
}
rectangle #CDEBA5 ":Universidad Disponible" as UniversidadDisponible

Visitante -r-> WelcomeView: iniciarVisita()

WelcomeView -d-> VisitaController: iniciar() : Visita

VisitaController --> Visita: new()

WelcomeView -r-> UniversidadDisponible: mostrarMenuPrincipal()

@enduml

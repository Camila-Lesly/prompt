@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

title Diagrama de Arquitectura - Fase Diseño Iteración 1

Person(admin, "Administrador", "Usuario principal del sistema")

System_Boundary(c1, "pySigHor Modernizado") {
    Container(web_app, "Single Page Application", "React + TypeScript + Vite", "Interfaz de usuario para gestión de horarios")
    Container(api, "API Backend", "Python + FastAPI", "Lógica de negocio y gestión de datos")
    ContainerDb(database, "Base de Datos", "SQLite", "Almacenamiento persistente")
}

Rel(admin, web_app, "Usa", "HTTPS")
Rel(web_app, api, "Realiza peticiones API", "JSON/HTTPS")
Rel(api, database, "Lee/Escribe", "SQL/SQLAlchemy")

@enduml

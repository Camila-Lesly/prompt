@startuml
title Diagrama de Secuencia - Editar Recurso
actor "Administrador" as Admin
participant "Frontend (React)" as FE
participant "API (FastAPI)" as API
participant "RecursoService" as Service
participant "RecursoRepository" as Repo
database "Base de Datos" as DB
Admin -> FE: Clic en "Editar" (en una fila)
activate FE
FE --> Admin: Mostrar Formulario con datos precargados
Admin -> FE: Modifica datos y Guardar
FE -> API: PUT /recursos/{id} (RecursoUpdate JSON)
activate API
API -> Service: editar_recurso(id, recurso_update)
activate Service
Service -> Repo: get_by_id(id)
activate Repo
Repo -> DB: SELECT * FROM recursos WHERE id = ?
activate DB
DB --> Repo: Recurso existente
deactivate DB
Repo --> Service: Recurso
deactivate Repo
Service -> Service: Actualizar campos
Service -> Repo: update(recurso)
activate Repo
Repo -> DB: UPDATE recursos SET ... WHERE id = ?
activate DB
DB --> Repo: OK
deactivate DB
Repo --> Service: Recurso actualizado
deactivate Repo
Service --> API: RecursoResponse
deactivate Service
API --> FE: 200 OK (Recurso JSON)
deactivate API
FE -> FE: Actualizar Lista / Notificar Éxito
FE --> Admin: Mostrar "Recurso actualizado correctamente"
deactivate FE
@enduml
